# Dominio interno de SIGEA con certificado interno/autofirmado emitido por Caddy.
{$SIGEA_DOMAIN} {
  encode gzip zstd
  tls internal
  reverse_proxy 172.28.10.12:80
}

# Ayuda mínima en HTTP si entran por IP o sin dominio
:80 {
  respond "SIGEA proxy activo. Configura SIGEA_DOMAIN y accede por https://{env.SIGEA_DOMAIN}" 200
}
