# ==============================================================================
# SIGEA - Variables de Entorno para Producción
# ==============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo:  cp .env.example .env
#   2. Edita el .env con los valores reales del servidor
#   3. NUNCA subas el .env a Git (ya está en .gitignore)
# ==============================================================================

# ── Base de datos ──────────────────────────────────────────────────────────────
MARIADB_DATABASE=sigea_db
MARIADB_USER=sigea_user
MARIADB_PASSWORD=CambiaMeSegura2026!
MARIADB_ROOT_PASSWORD=RootSegura2026!

# ── Zona horaria ───────────────────────────────────────────────────────────────
TZ=America/Bogota

# ── Backend - Conexión a BD ───────────────────────────────────────────────────
# Host recomendado para máxima compatibilidad en servidores con DNS Docker inestable:
# IP fija del contenedor DB en la red sigea-net (172.28.10.10)
SPRING_DATASOURCE_URL=jdbc:mariadb://172.28.10.10:3306/sigea_db?useUnicode=true&characterEncoding=UTF-8&serverTimezone=America/Bogota
SPRING_DATASOURCE_USERNAME=sigea_user
SPRING_DATASOURCE_PASSWORD=CambiaMeSegura2026!

# ── Backend - Almacenamiento de archivos ──────────────────────────────────────
SIGEA_UPLOADS_PATH=/app/uploads

# ── Backend - Verificación de email ──────────────────────────────────────────
# false = los usuarios se activan sin confirmar email (recomendado para inicio)
# true  = el usuario debe confirmar su email antes de poder entrar
SIGEA_AUTH_REQUIRE_EMAIL_VERIFICATION=false

# ── SMTP - Correo electrónico ─────────────────────────────────────────────────
# Gmail SMTP gratuito: requiere verificación en dos pasos y contraseña de aplicación.
# Cuenta remitente configurada para SIGEA.
SIGEA_SMTP_HOST=smtp.gmail.com
SIGEA_SMTP_PORT=587
SIGEA_SMTP_USERNAME=sigeasena@gmail.com
SIGEA_SMTP_PASSWORD=pega-aqui-la-contrasena-de-aplicacion-de-gmail
SIGEA_SMTP_AUTH=true
SIGEA_SMTP_STARTTLS=true
SIGEA_SMTP_SSL_TRUST=smtp.gmail.com
SIGEA_MAIL_FROM_NAME=SIGEA SENA

# ── URL pública de la aplicación ──────────────────────────────────────────────
# Se usa en los enlaces de los correos de verificación/recuperación y en CORS.
# Soporta múltiples orígenes separados por coma para entornos con IP + dominio.
# Ejemplo producción 443: https://sigea.web-virtual.com,https://192.168.4.250
SIGEA_APP_URL=https://sigea.web-virtual.com,https://192.168.4.250

# ── Dominio interno para HTTPS con certificado autofirmado/interno ───────────
# SIGEA_DOMAIN debe resolver en el DNS interno de la red hacia la IP privada del servidor.
# El certificado será emitido por el propio servidor/Caddy (tls internal), no por Let's Encrypt.
SIGEA_DOMAIN=sigea.web-virtual.com

# ── Puerto del frontend ───────────────────────────────────────────────────────
# Con Caddy en producción no se usa FRONTEND_PORT (se publica 80/443 directo).
FRONTEND_PORT=443

# ── HikariCP - Pool de conexiones (soporte 30+ usuarios concurrentes) ─────────
HIKARI_MAX_POOL_SIZE=40
HIKARI_MIN_IDLE=10
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000
